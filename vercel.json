{
  "version": 2,
  "builds" : [
    {

    "scr": "site/site_project/wsgi.py",
      "use": "@vercel/python",
      "config": {"maxLambdaSize" :  "15mb", "runtime":  "python3.9"}

    },
    {"scr": "build_files.sh",
    "use":  "@vercel/static-build",
    "config":  {"distDir":  "staticfiles_build"}
    }
    ],
  "routes": [
    {"scr" :  "/(.*)", "dest" :  "site/site_project/wsgi.py"}
    ]

}
